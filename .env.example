# ── Required for all modes ────────────────────────────────────────────────────
ASI1_API_KEY=your-asi1-api-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ── Embedding provider (pick one) ─────────────────────────────────────────────
# Gemini (default) — native 768-dim, no dimension mismatch risk
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# OpenAI alternative — also truncated to 768-dim automatically
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here

# ── Fetch.ai (uagents orchestration) ─────────────────────────────────────────
AGENTVERSE_API_KEY=your-agentverse-api-key-here

# ── Optional overrides ────────────────────────────────────────────────────────
# Bridge port (default 8080); set in both .env and VS Code setting traceback.bridgePort
# BRIDGE_PORT=8080

# ── Hosted mode (server-side only) ───────────────────────────────────────────
# When deploying the bridge as a hosted service, set the above vars as server
# environment variables (Railway, Fly.io, etc.).  Do NOT commit real keys.
# In VS Code, set traceback.bridgeUrl = https://your-bridge.fly.dev
# and leave traceback.pythonPath / local bridge vars unconfigured.
